// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int                @id @default(autoincrement())
  fullname          String
  email             String             @unique
  password          String
  role              String
  phone             String?
  address           String?
  profilePicture    String?
  ratings           Float? // average rating
  rides             Ride[]             @relation("RiderRides")
  rideRequests      RideRequest[]
  messages          Message[]          @relation("UserMessages")
  passengerRides    Ride[]             @relation("RidePassengers")
  createdRides      Ride[]             @relation("CreatedUser")
  ratingsGiven      Rating[]           @relation("FromUser")
  ratingsReceived   Rating[]           @relation("ToUser")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  karmaPoints       Int                @default(0) // Total karma points
  creditScore       Int                @default(0) // Total credit score for passengers
  karmaTransactions KarmaTransaction[]
  feedbackGiven     Feedback[]         @relation("FromUser")
  feedbackReceived  Feedback[]         @relation("ToUser")
  refreshTokens     RefreshToken[] // JWT refresh tokens
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

model Ride {
  id                     Int           @id @default(autoincrement())
  from                   String
  fromLat                Float?
  fromLng                Float?
  to                     String
  toLat                  Float?
  toLng                  Float?
  message                String?
  role                   String
  timestamp              DateTime      @default(now())
  createdBy              Int // ID of user who created the ride (could be passenger or rider)
  createdByUser          User          @relation("CreatedUser", fields: [createdBy], references: [id])
  rider                  User?         @relation("RiderRides", fields: [riderId], references: [id])
  estimatedTimeOfArrival Int? // ETA in minutes
  riderId                Int? // Made optional since it can be null for passenger-created rides
  passengerId            Int? // ID of the passenger who requested the ride (if applicable)
  requests               RideRequest[]
  passengers             User[]        @relation("RidePassengers")
  ratings                Rating[]
  messages               Message[]
  feedback               Feedback[]
  status                 RideStatus    @default(ACTIVE)
  distance               Float? // Distance in kilometers, calculated when ride is confirmed
  co2Saved               Float? // CO2 saved in kg
  peopleImpacted         Int? // Number of people impacted (passengers)
  matchGroupId           String? // UUID to group matched rides together
}

enum RideStatus {
  IDLE
  ACTIVE
  CONFIRMED
  REJECTED
  EXPIRED
  CANCELLED
  COMPLETED
}

model RideRequest {
  id          Int      @id @default(autoincrement())
  ride        Ride     @relation(fields: [rideId], references: [id])
  rideId      Int
  passenger   User     @relation(fields: [passengerId], references: [id])
  passengerId Int
  status      String // pending, accepted, rejected
  createdAt   DateTime @default(now())
}

model Rating {
  id         Int      @id @default(autoincrement())
  ride       Ride     @relation(fields: [rideId], references: [id])
  rideId     Int
  fromUser   User     @relation("FromUser", fields: [fromUserId], references: [id])
  fromUserId Int
  toUser     User     @relation("ToUser", fields: [toUserId], references: [id])
  toUserId   Int
  score      Int
  comment    String?
  createdAt  DateTime @default(now())
}

model Message {
  id        Int      @id @default(autoincrement())
  content   String
  sender    User     @relation("UserMessages", fields: [senderId], references: [id])
  senderId  Int
  ride      Ride?    @relation(fields: [rideId], references: [id])
  rideId    Int?
  createdAt DateTime @default(now())
}

model KarmaTransaction {
  id             Int               @id @default(autoincrement())
  user           User              @relation(fields: [userId], references: [id])
  userId         Int
  points         Int
  type           String
  reason         String?
  rewardName     String?
  redemptionCode String?
  status         RedemptionStatus?
  expiresAt      DateTime?
  usedAt         DateTime?
  createdAt      DateTime          @default(now())
}

model Feedback {
  id         Int      @id @default(autoincrement())
  ride       Ride     @relation(fields: [rideId], references: [id])
  rideId     Int
  fromUser   User     @relation("FromUser", fields: [fromUserId], references: [id])
  fromUserId Int
  toUser     User     @relation("ToUser", fields: [toUserId], references: [id])
  toUserId   Int
  role       String // role of the person giving feedback (rider/passenger)
  emoji      Int // emoji reaction index: 0=😊, 1=😐, 2=😠
  comment    String? // optional comment
  createdAt  DateTime @default(now())

  @@unique([rideId, fromUserId, toUserId]) // Prevent duplicate feedback
}

enum RedemptionStatus {
  ACTIVE
  USED
  EXPIRED
  LOCKED
}
